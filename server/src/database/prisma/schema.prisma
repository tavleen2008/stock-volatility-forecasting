// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id          String       @id @default(uuid())

  email       String       @unique
  name        String?

  password    String?

  avatarUrl   String?

  provider    AuthProvider @default(GOOGLE)
  providerId  String?

  isVerified  Boolean      @default(false)
  
  followedStocks String[]    @default([])

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([email])
}

enum AuthProvider {
  GOOGLE
  LOCAL
}

model NewsArticle {
  id          String   @id @default(uuid())

  symbol      String

  title       String

  description String?

  source      String?

  articleUrl  String   @unique

  publishedAt DateTime

  createdAt   DateTime @default(now())

  @@index([symbol])
  @@index([publishedAt])
}

model Forecast {
  id                  String   @id @default(uuid())
  symbol              String
  forecastDate        DateTime // The date the forecast is FOR
  forecastVolatility  Float
  confidenceScore     Float
  sentimentScore      Float
  fullPayload         Json     // Stores the entire rich ML response
  createdAt           DateTime @default(now())

  @@index([symbol, forecastDate])
}